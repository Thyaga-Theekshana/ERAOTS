# ============================================
# ERAOTS Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# Application
APP_NAME=ERAOTS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eraots
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-this-too
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Office Configuration
OFFICE_CAPACITY=100
OFFICE_TIMEZONE=Asia/Colombo
AUTO_CHECKOUT_HOUR=23
AUTO_CHECKOUT_MINUTE=59

# Notification Defaults
BREAK_THRESHOLD_MINUTES=30
GRACE_PERIOD_MINUTES=15

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@eraots.com

# WhatsApp (Twilio) - High priority only
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Scanner Simulator
SIMULATOR_ENABLED=true
SIMULATOR_EMPLOYEE_COUNT=20
SIMULATOR_SCAN_INTERVAL_SECONDS=30
